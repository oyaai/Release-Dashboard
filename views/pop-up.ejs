<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Error</title>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
  <script>
    Swal.fire({
      icon: 'error',
      title: 'เกิดข้อผิดพลาด',
      text: '<%= message %>',
      confirmButtonText: 'กลับไปหน้ากรอกข้อมูล'
    }).then((result) => {
      if (result.isConfirmed) {
        window.location.href = "<%= redirectUrl %>";
      }
    });
  </script>
</body>
</html>
